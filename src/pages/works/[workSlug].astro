---
import { ScrollReveal } from "../../components/ScrollReveal";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// All non-cover images under /src/assets/works/*/*.{jpg,jpeg,png,webp}
const imageImports = import.meta.glob<{
  default: ImageMetadata;
}>("../../assets/works/*/*.{jpg,jpeg,png,webp}", { eager: true });

export async function getStaticPaths() {
  const works = await getCollection("works");
  return works.map((entry) => ({ params: { workSlug: entry.id } }));
}

const { workSlug } = Astro.params;
const works = await getCollection("works");
const entry = works.find((w) => w.id === workSlug);
const normalizedWorkSlug = (workSlug ?? "").toLowerCase();

const title = entry?.data.title ?? workSlug?.replace(/-/g, " ") ?? "Work";
const description =
  entry?.data.description ??
  "This entry is not part of the mock catalog yet; add a matching record in the project data when you are ready. Until then you can still use the layout below as a template—swap in a longer centered intro, then wire the gallery to your own assets or CMS.";

// Pick all images from the matching folder, except files whose basename starts with 'cover'
const gallery = Object.entries(imageImports)
  .map(([path, mod]) => {
    const match = path.match(/\/works\/([^/]+)\/([^/]+)\.[^.]+$/);
    if (!match) return null;
    const [, id, basename] = match;
    if (id.toLowerCase() !== normalizedWorkSlug) return null;
    if (basename.toLowerCase().startsWith("cover")) return null;
    return mod.default;
  })
  .filter(Boolean) as ImageMetadata[];
---

<Layout title={`${title} — urszulaturewicz`}>
  <article class="">
    <header class="page-enter space-y-4">
      <h1
        class="font-decorative text-center text-3xl pt-8 pb-6 font-semibold tracking-tight"
      >
        {title}
      </h1>
      <p
        class={`
        mx-auto max-w-[60ch] text-center text-base leading-relaxed tracking-wide px-2
         text-zinc-600 [&_p]:m-0 [&_strong]:font-normal [&_strong]:text-[#2CFF05] sm:text-lg
         `}
      >
        {description}
      </p>
    </header>
    <div class="sticky inline-block top-5 z-10">
      <a
        href="/"
        class="uppercase items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-zinc-900"
      >
        <span class="nav-chevron-left mb-0.25" aria-hidden></span>
        Back to home
      </a>
    </div>
    {
      gallery.length > 0 ? (
        <div class="flex flex-col gap-6 pt-2 pb-8">
          {gallery.map((src, index) => (
            <ScrollReveal client:visible className="w-full">
              <figure class="m-0 aspect-4/3 w-full overflow-hidden">
                <Image
                  src={src}
                  alt={`${title} — image ${index + 1}`}
                  width={2400}
                  class="h-full w-full object-contain"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </figure>
            </ScrollReveal>
          ))}
        </div>
      ) : (
        <p class="text-sm text-zinc-500">
          No images in the gallery for this entry.
        </p>
      )
    }
  </article>
</Layout>

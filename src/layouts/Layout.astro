---
import "../index.css";

type Props = {
  title?: string;
};

const { title = "urszulaturewicz" } = Astro.props;
const pathname = Astro.url.pathname;
const isWorkSubpage = pathname.split("/").includes("works");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-50 text-zinc-900">
    <div class="flex min-h-dvh flex-col">
      <header class="shrink-0">
        <div class="mx-auto max-w-[1200px] px-6 pb-4 pt-8 text-center">
          <a
            href="/"
            class="text-base font-medium uppercase tracking-[0.35em] text-zinc-900 sm:text-lg"
          >
            urszula turewicz
          </a>
        </div>
      </header>
      <nav
        class="sticky top-0 z-10 w-full shrink-0 bg-zinc-50/80 py-4 backdrop-blur"
        aria-label="Main"
      >
        <div class="mx-auto flex max-w-[1200px] flex-col items-center px-6">
          <div
            class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2"
          >
            <a
              href="/"
              class:list={[
                "text-sm transition-colors",
                pathname === "/"
                  ? "text-zinc-900"
                  : "text-zinc-500 hover:text-zinc-900",
              ]}
            >
              Works
            </a>
            <a
              href="/about"
              class:list={[
                "text-sm transition-colors",
                pathname === "/about"
                  ? "text-zinc-900"
                  : "text-zinc-500 hover:text-zinc-900",
              ]}
            >
              About
            </a>
            <a
              href="/contact"
              class:list={[
                "text-sm transition-colors",
                pathname === "/contact"
                  ? "text-zinc-900"
                  : "text-zinc-500 hover:text-zinc-900",
              ]}
            >
              Contact
            </a>
          </div>
          {
            isWorkSubpage ? (
              <div class="mt-4 flex w-full justify-start self-stretch border-t border-zinc-200/80 pt-4">
                <a
                  href="/"
                  class="inline-flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-zinc-900"
                >
                  <span class="nav-chevron-left" aria-hidden />
                  Back to home
                </a>
              </div>
            ) : null
          }
        </div>
      </nav>
      <main class="mx-auto w-full max-w-[1200px] flex-1">
        <slot />
      </main>
    </div>
  </body>
</html>

---
import { getContrastingTextColor } from "../theme/homePageCardPalette";
import { Image } from "astro:assets";

type Props = {
  work: {
    workSlug: string;
    title: string;
    imageSource?: ImageMetadata;
  };
  color: string;
  textColor?: string;
};

const { work, color, textColor: textColorProp } = Astro.props;
const { workSlug, title, imageSource } = work;
const titleColor = textColorProp ?? getContrastingTextColor(color);
---

<a
  href={`/works/${workSlug}`}
  aria-label={`View work: ${title}`}
  class="group relative block aspect-square overflow-hidden outline-none ring-violet-500/30 focus-visible:ring-2"
  style={{ backgroundColor: color }}
>
  {
    imageSource && (
      <Image
        src={imageSource}
        alt={title}
        width={800}
        height={800}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-opacity duration-300 ease-out group-hover:opacity-0 group-focus-within:opacity-0"
      />
    )
  }
  <div
    class="absolute inset-0 flex items-center justify-center p-4 opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100 group-focus-within:opacity-100"
    style={{ backgroundColor: color }}
  >
    <span
      class="font-decorative leading-relaxed tracking-wide text-center text-lg sm:text-2xl max-w-[280px] px-2 mx-auto"
      style={{ color: titleColor }}
    >
      {title}
    </span>
  </div>
</a>
